    "def get_scaffold(smiles):\n",
    "    mol = Chem.MolFromSmiles(smiles)\n",
    "    if mol is None:\n",
    "        return None\n",
    "    scaffold = MurckoScaffold.GetScaffoldForMol(mol)\n",
    "    return Chem.MolToSmiles(scaffold)\n",
    "\n",
    "tox[\"scaffold\"] = tox[\"smiles\"].apply(get_scaffold).astype(str)\n",
    "\n",
    "tox.head()"
   ]
  },
